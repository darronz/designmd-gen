{
  "name": "@darronz/designmd-gen",
  "version": "0.1.0",
  "description": "Export DESIGN.md from existing design token sources",
  "type": "module",
  "bin": {
    "designmd-gen": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@google/design.md": "^0.1.1",
    "commander": "^13.0.0",
    "culori": "^4.0.0",
    "jiti": "^2.4.0",
    "postcss": "^8.5.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/culori": "^2.1.0",
    "@types/node": "^22.0.0",
    "np": "^11.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
